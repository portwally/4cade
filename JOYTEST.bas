 10  HOME
 20  PRINT "JOYSTICK TESTER"
 30  PRINT "==============="
 40  PRINT
 50  PRINT "PRESS CTRL-C TO QUIT"
 60  REM DRAW BOX ONCE
 70  HTAB 1: VTAB 13
 80  PRINT "+";
 90  FOR I = 1 TO 38: PRINT "-";: NEXT
100  PRINT "+"
110  FOR R = 1 TO 18
120  PRINT "|";
130  FOR I = 1 TO 38: PRINT " ";: NEXT
140  PRINT "|"
150  NEXT R
160  PRINT "+";
170  FOR I = 1 TO 38: PRINT "-";: NEXT
180  PRINT "+"
190  OX = 0:OY = 0
200  REM MAIN LOOP
210  X = PDL (0)
220  Y = PDL (1)
230  B0 = PEEK (49249)
240  B1 = PEEK (49250)
250  HTAB 1: VTAB 6
260  PRINT "PADDLE 0 (X): ";X;"   "
270  HTAB 1: VTAB 7
280  PRINT "PADDLE 1 (Y): ";Y;"   "
290  HTAB 1: VTAB 9
300  IF B0 > 127 THEN  PRINT "BUTTON 0: ** PRESSED **  ";: GOTO 320
310  PRINT "BUTTON 0:    RELEASED    ";
320  HTAB 1: VTAB 10
330  IF B1 > 127 THEN  PRINT "BUTTON 1: ** PRESSED **  ";: GOTO 350
340  PRINT "BUTTON 1:    RELEASED    ";
350  REM ERASE OLD CURSOR
360  IF OX = 0 THEN 390
370  HTAB OX: VTAB OY
380  PRINT " ";
390  REM DRAW NEW CURSOR
400  CX = INT (X / 255 * 38) + 2
410  CY = INT (Y / 255 * 18) + 14
420  HTAB CX: VTAB CY
430  PRINT "*";
440  OX = CX:OY = CY
450  GOTO 210
